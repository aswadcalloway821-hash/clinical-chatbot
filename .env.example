# Server Configuration
PORT=3000

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Google Credentials (JSON key string or path to JSON file)
GOOGLE_APPLICATION_CREDENTIALS=google-creds.json
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id_here

# WhatsApp API Configuration
WHATSAPP_VERIFY_TOKEN=your_webhook_verification_token_here
WHATSAPP_API_TOKEN=your_meta_graph_api_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
